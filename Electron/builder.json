{
  "appId": "dev.twiliophone.desktop",
  "productName": "Twilio Phone",
  "files": [
    "main.js",
    "preload.js",
    "renderer/**/*",
    "backend-dist/**/*",
    "!backend-dist/**/*.test.js",
    "assets/**/*",
    "package.json"
  ],
  "directories": {
    "buildResources": "assets"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Network"
  },
  "mac": { "category": "public.app-category.productivity" },
  "win": { "target": ["nsis"] }
}
