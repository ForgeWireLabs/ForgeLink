{
  "appId": "dev.forgelink.desktop",
  "productName": "ForgeLink",
  "files": [
    "main.js",
    "preload.js",
    "onboarding.js",
    "renderer/index.html",
    "renderer/styles.css",
    "renderer/app.js",
    "backend-dist/**/*",
    "!backend-dist/**/*.test.js",
    "assets/**/*",
    "package.json"
  ],
  "directories": {
    "buildResources": "assets"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Network"
  },
  "mac": { "category": "public.app-category.productivity" },
  "win": { "target": ["nsis"] }
}
